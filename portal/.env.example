# =============================================================================
# Variaveis de ambiente obrigatorias para deploy (Vercel / producao)
# =============================================================================
# Copie este arquivo para .env.local para desenvolvimento local.
# No Vercel, configure cada variavel em: Settings > Environment Variables.
# =============================================================================

# --- Supabase (obrigatorias) -------------------------------------------------
# URL do projeto Supabase (encontrada em Settings > API no dashboard Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Chave anon/publica do Supabase (Settings > API > anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role do Supabase (Settings > API > service_role)
# NUNCA expor com prefixo NEXT_PUBLIC_ — usada apenas no servidor
SUPABASE_SERVICE_KEY=eyJ...

# --- Admin -------------------------------------------------------------------
# Emails dos administradores (separados por virgula) — quem pode acessar /admin
# Deixe vazio para permitir qualquer usuario autenticado acessar o admin (modo dev)
ADMIN_EMAILS=pedro.souza53321+dev@gmail.com
